{
    "problems": [
        {
            "id": "unix_001",
            "title": "Print Hello",
            "description": "Write a command that prints exactly: Hello, World!",
            "difficulty": "easy",
            "tests": [
                {
                    "input": "",
                    "expected_stdout": "Hello, World!\n"
                }
            ]
        },
        {
            "id": "unix_002",
            "title": "Count Files",
            "description": "Count how many files are in the current directory.",
            "difficulty": "easy",
            "tests": [
                {
                    "setup_files": [
                        "a.txt",
                        "b.txt",
                        "c.txt"
                    ],
                    "expected_stdout": "3\n"
                },
                {
                    "setup_files": [
                        "one",
                        "two"
                    ],
                    "expected_stdout": "2\n"
                }
            ]
        },
        {
            "id": "unix_003",
            "title": "Print Working Directory",
            "description": "Output the current directory path.",
            "difficulty": "easy",
            "tests": [
                {
                    "cwd": "/home/user",
                    "expected_stdout": "/home/user\n"
                }
            ]
        },
        {
            "id": "unix_004",
            "title": "Show First Line",
            "description": "Print only the first line of a file named input.txt.",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "apple\nbanana\ncarrot\n"
                    },
                    "expected_stdout": "apple\n"
                }
            ]
        },
        {
            "id": "unix_005",
            "title": "Count Lines",
            "description": "Print the number of lines in input.txt.",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "a\nb\nc\n"
                    },
                    "expected_stdout": "3\n"
                },
                {
                    "files": {
                        "input.txt": "hello\n"
                    },
                    "expected_stdout": "1\n"
                }
            ]
        },
        {
            "id": "unix_006",
            "title": "Find Word",
            "description": "Print lines from input.txt that contain the word apple.",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "apple\nbanana\napple pie\n"
                    },
                    "expected_stdout": "apple\napple pie\n"
                }
            ]
        },
        {
            "id": "unix_007",
            "title": "Sort Lines",
            "description": "Sort lines of input.txt alphabetically.",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "dog\napple\ncat\n"
                    },
                    "expected_stdout": "apple\ncat\ndog\n"
                }
            ]
        },
        {
            "id": "unix_008",
            "title": "Unique Lines",
            "description": "Print unique lines from input.txt (remove duplicates).",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "a\na\nb\nb\nc\n"
                    },
                    "expected_stdout": "a\nb\nc\n"
                }
            ]
        },
        {
            "id": "unix_009",
            "title": "Count Words",
            "description": "Print the number of words in input.txt.",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "hello world\nunix is fun\n"
                    },
                    "expected_stdout": "5\n"
                }
            ]
        },
        {
            "id": "unix_010",
            "title": "Replace Word",
            "description": "Replace all occurrences of 'cat' with 'dog' in input.txt and print result.",
            "difficulty": "easy",
            "tests": [
                {
                    "files": {
                        "input.txt": "cat sat on cat\n"
                    },
                    "expected_stdout": "dog sat on dog\n"
                }
            ]
        }
    ]
}