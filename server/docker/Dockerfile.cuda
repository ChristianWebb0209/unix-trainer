# CUDA workspace image
FROM nvidia/cuda:12.4.0-devel-ubuntu22.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      bash \
      coreutils \
      nano \
      vim \
      build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]

